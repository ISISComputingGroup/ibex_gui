        <rules>
          <rule name="X" prop_id="trace_0_x_pv" out_exp="true">
            <exp bool_exp="true">
              <value>"pva://$(P)KDAEDIAG:SPEC:"+pvInt1+":"+pvInt0+":X"</value>
